<UserControl x:Class="DigitalTwin.Shell.Views.LeftPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:vm="clr-namespace:DigitalTwin.Shell.ViewModels"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="Transparent">

    <UserControl.Resources>

        <!-- 日志条目模板 -->
        <DataTemplate x:Key="LogItemTp1">
            <Grid Margin="0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52"/>
                    <!-- 时间 -->
                    <ColumnDefinition Width="32"/>
                    <!-- 级别 -->
                    <ColumnDefinition Width="*"/>
                    <!-- 消息 -->
                </Grid.ColumnDefinitions>

                <!-- 时间 -->
                <TextBlock Grid.Column="0"
               Text="{Binding TimeText}"
               Foreground="#606880"
               FontSize="10"
               VerticalAlignment="Center"/>

                <!-- 级别标签（带颜色） -->
                <Border Grid.Column="1"
            Background="Transparent"
            CornerRadius="2"
            Padding="3,1"
            Margin="2,0">
                    <TextBlock Text="{Binding LevelText}"
                   Foreground="{Binding LevelColor}"
                   FontSize="9"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>
                </Border>

                <!-- 消息内容 -->
                <TextBlock Grid.Column="2"
               Text="{Binding Message}"
               Foreground="{Binding MessageColor}"
               FontSize="10"
               TextWrapping="NoWrap"
               TextTrimming="CharacterEllipsis"
               VerticalAlignment="Center"
               Margin="4,0,0,0"
               ToolTip="{Binding Message}"/>
            </Grid>
        </DataTemplate>

        <Style x:Key="StatusDot" TargetType="Ellipse">
            <Setter Property="Width"  Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Fill"   Value="#FF3D5570"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:DeviceStatus.Running}">
                    <Setter Property="Fill" Value="#FF00E5A0"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:DeviceStatus.Warning}">
                    <Setter Property="Fill" Value="#FFFFB020"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:DeviceStatus.Error}">
                    <Setter Property="Fill" Value="#FFFF3D5A"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:DeviceStatus.Idle}">
                    <Setter Property="Fill" Value="#FF7899BB"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatusTagText" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Text"       Value="离线"/>
            <Setter Property="Foreground" Value="#FF3D5570"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:DeviceStatus.Running}">
                    <Setter Property="Text"       Value="运行"/>
                    <Setter Property="Foreground" Value="#FF00E5A0"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:DeviceStatus.Warning}">
                    <Setter Property="Text"       Value="警告"/>
                    <Setter Property="Foreground" Value="#FFFFB020"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:DeviceStatus.Error}">
                    <Setter Property="Text"       Value="故障"/>
                    <Setter Property="Foreground" Value="#FFFF3D5A"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:DeviceStatus.Idle}">
                    <Setter Property="Text"       Value="待机"/>
                    <Setter Property="Foreground" Value="#FF7899BB"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DeviceListItem" TargetType="ListBoxItem">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="Padding"         Value="8"/>
            <Setter Property="Margin"          Value="0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#08FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background"  Value="#1A00D8FF"/>
                                <Setter Property="BorderBrush" Value="#3300D8FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Log 级别颜色 -->
        <Style x:Key="LogLevelInfo" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize"   Value="9"/>
            <Setter Property="Foreground" Value="#FF3D7FFF"/>
            <Setter Property="Text"       Value="INFO"/>
        </Style>
        <Style x:Key="LogLevelWarn" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize"   Value="9"/>
            <Setter Property="Foreground" Value="#FFFFB020"/>
            <Setter Property="Text"       Value="WARN"/>
        </Style>
        <Style x:Key="LogLevelError" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize"   Value="9"/>
            <Setter Property="Foreground" Value="#FFFF3D5A"/>
            <Setter Property="Text"       Value="ERR "/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="250"/>
            <!-- 设备列表 -->
            <RowDefinition Height="Auto"/>
            <!-- 实时数据 -->
            <RowDefinition Height="Auto"/>
            <!-- OEE -->
            <RowDefinition Height="180"/>
            <!-- 实时日志 -->
        </Grid.RowDefinitions>

        <!-- ══ 设备列表 ══ -->
        <Border Grid.Row="0"
                BorderBrush="#FF1E2D45" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="14,10,14,8">
                    <TextBlock Text="设备列表"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="#FF3D5570"
                               VerticalAlignment="Center"/>
                    <TextBlock HorizontalAlignment="Right"
                               FontFamily="Consolas" FontSize="10"
                               Foreground="#FF00D8FF"
                               Text="{Binding OnlineCountText}"
                               VerticalAlignment="Center"/>
                </Grid>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Devices}"
                         SelectedItem="{Binding SelectedDevice}"
                         ItemContainerStyle="{StaticResource DeviceListItem}"
                         Background="Transparent" BorderThickness="0"
                         Margin="8,0,8,8"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Ellipse Grid.Column="0"
                                         Style="{StaticResource StatusDot}"
                                         Margin="0,0,10,0"
                                         VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="#FFDDEEFF"/>
                                    <TextBlock Text="{Binding IpAddress}"
                                               FontFamily="Consolas" FontSize="10"
                                               Foreground="#FF3D5570"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2"
                                           Style="{StaticResource StatusTagText}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ══ 实时数据 ══ -->
        <Border Grid.Row="1"
                BorderBrush="#FF1E2D45" BorderThickness="0,0,0,1">
            <StackPanel>
                <Grid Margin="14,10,14,6">
                    <TextBlock FontSize="10" FontWeight="SemiBold"
                               Foreground="#FF3D5570"
                               Text="{Binding SelectedDevice.DisplayName,
                                      StringFormat={}{0} · 实时数据}"/>
                    <TextBlock HorizontalAlignment="Right"
                               FontFamily="Consolas" FontSize="10">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text"       Value="待机"/>
                                <Setter Property="Foreground" Value="#FF7899BB"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedDevice.Status}"
                                                 Value="{x:Static vm:DeviceStatus.Running}">
                                        <Setter Property="Text"       Value="● 运行中"/>
                                        <Setter Property="Foreground" Value="#FF00E5A0"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedDevice.Status}"
                                                 Value="{x:Static vm:DeviceStatus.Warning}">
                                        <Setter Property="Text"       Value="● 警告"/>
                                        <Setter Property="Foreground" Value="#FFFFB020"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedDevice.Status}"
                                                 Value="{x:Static vm:DeviceStatus.Error}">
                                        <Setter Property="Text"       Value="● 故障"/>
                                        <Setter Property="Foreground" Value="#FFFF3D5A"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <StackPanel Margin="12,0,12,10">

                    <!-- X 轴 -->
                    <StackPanel Margin="0,0,0,10">
                        <Grid Margin="0,0,0,5">
                            <TextBlock FontSize="11" FontWeight="SemiBold"
                                       Foreground="#FF3D5570" Text="X 轴 · 行走"/>
                            <TextBlock HorizontalAlignment="Right"
                                       FontFamily="Consolas" FontSize="13"
                                       Foreground="#FF00D8FF"
                                       Text="{Binding SelectedDevice.XPositionText}"/>
                        </Grid>
                        <Grid Height="6">
                            <Border Background="#FF1A2336" CornerRadius="3"/>
                            <Border CornerRadius="3" HorizontalAlignment="Left">
                              
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF004488" Offset="0"/>
                                        <GradientStop Color="#FF3D7FFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <!-- Y 轴 -->
                    <StackPanel Margin="0,0,0,10">
                        <Grid Margin="0,0,0,5">
                            <TextBlock FontSize="11" FontWeight="SemiBold"
                                       Foreground="#FF3D5570" Text="Y 轴 · 提升"/>
                            <TextBlock HorizontalAlignment="Right"
                                       FontFamily="Consolas" FontSize="13"
                                       Foreground="#FF00E5A0"
                                       Text="{Binding SelectedDevice.YPositionText}"/>
                        </Grid>
                        <Grid Height="6">
                            <Border Background="#FF1A2336" CornerRadius="3"/>
                            <Border CornerRadius="3" HorizontalAlignment="Left">
                                
                                
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF003322" Offset="0"/>
                                        <GradientStop Color="#FF00E5A0" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <!-- Z 轴 -->
                    <StackPanel Margin="0,0,0,10">
                        <Grid Margin="0,0,0,5">
                            <TextBlock FontSize="11" FontWeight="SemiBold"
                                       Foreground="#FF3D5570" Text="Z 轴 · 货叉"/>
                            <TextBlock HorizontalAlignment="Right"
                                       FontFamily="Consolas" FontSize="13"
                                       Foreground="#FFFFB020"
                                       Text="{Binding SelectedDevice.ZPositionText}"/>
                        </Grid>
                        <Grid Height="6">
                            <Border Background="#FF1A2336" CornerRadius="3"/>
                            <Border CornerRadius="3" HorizontalAlignment="Left">
                                
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF332200" Offset="0"/>
                                        <GradientStop Color="#FFFFB020" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <!-- 温度 -->
                    <StackPanel Margin="0,0,0,10">
                        <Grid Margin="0,0,0,5">
                            <TextBlock FontFamily="Consolas" FontSize="10"
                                       Foreground="#FF3D5570" Text="控制器温度"/>
                            <TextBlock HorizontalAlignment="Right"
                                       FontFamily="Consolas" FontSize="10"
                                       Foreground="#FFFFB020"
                                       Text="{Binding SelectedDevice.TemperatureText}"/>
                        </Grid>
                        <Grid Height="4">
                            <Border Background="#FF1A2336" CornerRadius="2"/>
                            <Border CornerRadius="2" HorizontalAlignment="Left">
                                
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF00A8CC" Offset="0"/>
                                        <GradientStop Color="#FFFFB020" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <!-- 电机电流 -->
                    <Grid>
                        <TextBlock FontFamily="Consolas" FontSize="10"
                                   Foreground="#FF3D5570" Text="电机电流"
                                   VerticalAlignment="Center"/>
                        <TextBlock HorizontalAlignment="Right"
                                   FontFamily="Consolas" FontSize="12"
                                   Foreground="#FF00D8FF"
                                   Text="{Binding SelectedDevice.MotorCurrent,
                                          StringFormat={}{0:F1} A}"
                                   VerticalAlignment="Center"/>
                    </Grid>

                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══ OEE ══ -->
        <Border Grid.Row="2"
                BorderBrush="#FF1E2D45" BorderThickness="0,0,0,1"
                Padding="0,0,0,8">
            <StackPanel>
                <Grid Margin="14,10,14,8">
                    <TextBlock Text="今日 OEE"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="#FF3D5570"/>
                    <TextBlock HorizontalAlignment="Right"
                               FontFamily="Consolas" FontSize="10"
                               Foreground="#FF3D5570" Text="班次 A"/>
                </Grid>

                <ItemsControl ItemsSource="{Binding OeeItems}" Margin="12,0,12,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,8">
                                <TextBlock FontFamily="Consolas" FontSize="10"
                                           Foreground="#FF3D5570"
                                           Text="{Binding Label}"
                                           VerticalAlignment="Center"/>
                                <TextBlock HorizontalAlignment="Right"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="{Binding ValueBrush}"
                                           Text="{Binding ValueText}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ══ 实时日志 ══ -->
        <Border Grid.Row="3"
                BorderBrush="#FF1E2D45" BorderThickness="0,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 标题栏 -->
                <Grid Grid.Row="0" Margin="14,10,14,6">
                    <TextBlock Text="实时日志"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="#FF3D5570"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <!-- 日志计数 -->
                        <TextBlock FontFamily="Consolas" FontSize="10"
                                   Foreground="#FF3D5570"
                                   VerticalAlignment="Center"
                                   Text="{Binding RealtimeLogs.Count,
                                          StringFormat={}{0} 条}"
                                   Margin="0,0,10,0"/>
                        <!-- 清空按钮 -->
                        <Border Padding="6,2" CornerRadius="2"
                                BorderBrush="#FF1E2D45" BorderThickness="1"
                                Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding ClearLogsCommand}"/>
                            </Border.InputBindings>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#FF3D5570"/>
                                            <Setter Property="Background"  Value="#08FFFFFF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="清空"
                                       FontFamily="Consolas" FontSize="10"
                                       Foreground="#FF3D5570"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- 日志列表 -->
                <ScrollViewer Grid.Row="1"
                              x:Name="LogScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Logs}"
                                  Margin="0,0,4,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,4"
                                        BorderBrush="#FF1E2D45"
                                        BorderThickness="0,0,0,1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Level}"
                                                             Value="Error">
                                                    <Setter Property="Background"
                                                            Value="#08FF3D5A"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}"
                                                             Value="Warn">
                                                    <Setter Property="Background"
                                                            Value="#08FFB020"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32"/>
                                            <!-- 级别 -->
                                            <ColumnDefinition Width="54"/>
                                            <!-- 时间 -->
                                            <ColumnDefinition Width="*"/>
                                            <!-- 内容 -->
                                        </Grid.ColumnDefinitions>

                                        <!-- 级别标签 -->
                                        <TextBlock Grid.Column="0"
                                                   FontFamily="Consolas" FontSize="9"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text"       Value="INFO"/>
                                                    <Setter Property="Foreground" Value="#FF3D7FFF"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Level}"
                                                                     Value="Warning">
                                                            <Setter Property="Text"
                                                                    Value="WARN"/>
                                                            <Setter Property="Foreground"
                                                                    Value="#FFFFB020"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}"
                                                                     Value="Error">
                                                            <Setter Property="Text"
                                                                    Value="ERR "/>
                                                            <Setter Property="Foreground"
                                                                    Value="#FFBF5353"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}"
                                                                     Value="Success">
                                                            <Setter Property="Text"
                                                                    Value="OK  "/>
                                                            <Setter Property="Foreground"
                                                                    Value="#FF00E5A0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}"
                                                                    Value="Fatal">
                                                            <Setter Property="Text"
                                                                    Value="OK  "/>
                                                            <Setter Property="Foreground"
                                                                    Value="#FFF70909"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- 时间戳 -->
                                        <TextBlock Grid.Column="1"
                                                   FontFamily="Consolas" FontSize="9"
                                                   Foreground="#FF3D5570"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding TimeText}"/>

                                        <!-- 日志内容 -->
                                        <TextBlock Grid.Column="2"
                                                   FontFamily="Consolas" FontSize="10"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Message}"
                                                   Text="{Binding Message}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground"
                                                            Value="#FF7899BB"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Level}"
                                                                     Value="Warn">
                                                            <Setter Property="Foreground"
                                                                    Value="#FFFFB020"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}"
                                                                     Value="Error">
                                                            <Setter Property="Foreground"
                                                                    Value="#FFFF3D5A"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}"
                                                                     Value="Success">
                                                            <Setter Property="Foreground"
                                                                    Value="#FF00E5A0"/>
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding Level}"
                                                                    Value="Debug">
                                                            <Setter Property="Foreground"
                                                                    Value="#FF237CD4"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

    </Grid>
</UserControl>
