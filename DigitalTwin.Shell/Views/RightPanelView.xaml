<UserControl x:Class="DigitalTwin.Shell.Views.RightPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="TaskBadge" TargetType="Border">
            <Setter Property="CornerRadius"    Value="2"/>
            <Setter Property="Padding"         Value="7,2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#FF1E2D45"/>
            <Setter Property="Background"      Value="Transparent"/>
        </Style>

        <Style x:Key="ListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding"         Value="14,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="#FF1E2D45"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#06FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="180"/>
            <!-- KPI -->
            <RowDefinition Height="Auto"/>
            <!-- 热力图 -->
            <RowDefinition Height="160"/>
            <!-- 报警列表 -->
            <RowDefinition Height="*"/>
            <!-- 任务队列 -->
        </Grid.RowDefinitions>

        <!-- ══ KPI 四宫格 ══ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- 库位占用率 -->
            <Border Grid.Row="0" Grid.Column="0"
                    Background="#FF0F1520" Padding="12,10"
                    BorderBrush="#FF1E2D45" BorderThickness="0,0,1,1">
                <StackPanel>
                    <TextBlock Text="库位占用率" FontSize="10" FontWeight="SemiBold"
                               Foreground="#FF3D5570"
                               Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="26" FontWeight="Bold"
                                   Foreground="#FF00D8FF"
                                   Text="{Binding OccupancyRate, StringFormat={}{0:F1}}"/>
                        <TextBlock FontSize="16" FontWeight="Bold"
                                   Foreground="#FF00D8FF"
                                   VerticalAlignment="Bottom"
                                   Text="%" Margin="1,0,0,2"/>
                    </StackPanel>
                    <TextBlock FontFamily="Consolas" FontSize="9"
                               Foreground="#FF3D5570" Margin="0,2,0,0"
                               Text="{Binding OccupancyDelta}"/>
                </StackPanel>
            </Border>

            <!-- 今日吞吐量 -->
            <Border Grid.Row="0" Grid.Column="1"
                    Background="#FF0F1520" Padding="12,10"
                    BorderBrush="#FF1E2D45" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="今日吞吐量" FontSize="10" FontWeight="SemiBold"
                               Foreground="#FF3D5570"
                               Margin="0,0,0,4"/>
                    <TextBlock FontSize="26" FontWeight="Bold"
                               Foreground="#FF00E5A0"
                               Text="{Binding TodayThroughput, StringFormat={}{0:N0}}"/>
                    <TextBlock FontFamily="Consolas" FontSize="9"
                               Foreground="#FF3D5570" Margin="0,2,0,0"
                               Text="{Binding ThroughputDetail}"/>
                </StackPanel>
            </Border>

            <!-- 活跃报警 -->
            <Border Grid.Row="1" Grid.Column="0"
                    Background="#FF0F1520" Padding="12,10"
                    BorderBrush="#FF1E2D45" BorderThickness="0,0,1,0">
                <StackPanel>
                    <TextBlock Text="活跃报警" FontSize="10" FontWeight="SemiBold"
                               Foreground="#FF3D5570"
                               Margin="0,0,0,4"/>
                    <TextBlock FontSize="26" FontWeight="Bold"
                               Foreground="#FFFF3D5A"
                               Text="{Binding ActiveAlarmCount}"/>
                    <TextBlock FontFamily="Consolas" FontSize="9"
                               Foreground="#FF3D5570" Margin="0,2,0,0"
                               Text="{Binding UnacknowledgedText}"/>
                </StackPanel>
            </Border>

            <!-- 任务队列KPI -->
            <Border Grid.Row="1" Grid.Column="1"
                    Background="#FF0F1520" Padding="12,10">
                <StackPanel>
                    <TextBlock Text="任务队列" FontSize="10" FontWeight="SemiBold"
                               Foreground="#FF3D5570"
                               Margin="0,0,0,4"/>
                    <TextBlock FontSize="26" FontWeight="Bold"
                               Foreground="#FFFFB020"
                               Text="{Binding TotalTaskCount}"/>
                    <TextBlock FontFamily="Consolas" FontSize="9"
                               Foreground="#FF3D5570" Margin="0,2,0,0"
                               Text="{Binding TaskQueueDetail}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══ 热力图 ══ -->
        <Border Grid.Row="1"
                BorderBrush="#FF1E2D45" BorderThickness="0,1,0,0"
                Padding="12,10">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <TextBlock Text="库存热力图" FontSize="10" FontWeight="SemiBold"
                               Foreground="#FF3D5570"/>
                    <TextBlock HorizontalAlignment="Right"
                               FontFamily="Consolas" FontSize="10"
                               Foreground="#FF00D8FF"
                               Text="{Binding HeatmapSubtitle}"/>
                </Grid>

                <ItemsControl ItemsSource="{Binding HeatmapCells}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="12" Rows="8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Height="14" Margin="1" CornerRadius="1"
                                    Cursor="Hand" ToolTip="{Binding Tooltip}">
                                
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 图例 -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,6,0,0">
                    <TextBlock FontFamily="Consolas" FontSize="9"
                               Foreground="#FF3D5570"
                               VerticalAlignment="Center" Text="空 "/>
                    <Rectangle Width="10" Height="10" Margin="1,0" RadiusX="1" RadiusY="1" Fill="#FF1A2336"/>
                    <Rectangle Width="10" Height="10" Margin="1,0" RadiusX="1" RadiusY="1" Fill="#FF004466"/>
                    <Rectangle Width="10" Height="10" Margin="1,0" RadiusX="1" RadiusY="1" Fill="#FF006E99"/>
                    <Rectangle Width="10" Height="10" Margin="1,0" RadiusX="1" RadiusY="1" Fill="#FF009ABB"/>
                    <Rectangle Width="10" Height="10" Margin="1,0" RadiusX="1" RadiusY="1" Fill="#FF00BED8"/>
                    <Rectangle Width="10" Height="10" Margin="1,0" RadiusX="1" RadiusY="1" Fill="#FF00D8FF"/>
                    <TextBlock FontFamily="Consolas" FontSize="9"
                               Foreground="#FF3D5570"
                               VerticalAlignment="Center" Text=" 满"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══ 报警列表 ══ -->
        <Border Grid.Row="2"
                BorderBrush="#FF1E2D45" BorderThickness="0,1,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 标题 -->
                <Grid Grid.Row="0" Margin="14,8,14,6">
                    <TextBlock Text="活跃报警" FontSize="10" FontWeight="SemiBold"
                               Foreground="#FF3D5570"/>
                    <TextBlock HorizontalAlignment="Right"
                               FontFamily="Consolas" FontSize="10"
                               Foreground="#FFFF3D5A"
                               Text="{Binding ActiveAlarmCount, StringFormat={}{0} 条}"/>
                </Grid>

                <!-- 列表 -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding ActiveAlarms}"
                         ItemContainerStyle="{StaticResource ListItemStyle}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Rectangle Grid.Column="0" Margin="0,0,10,0"
                                           Fill="{Binding LevelBrush}"
                                           RadiusX="1.5" RadiusY="1.5"/>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="#FFDDEEFF"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock FontFamily="Consolas" FontSize="10"
                                               Foreground="#FF3D5570" Margin="0,2,0,0">
                                        <Run Text="{Binding Code}"/>
                                        <Run Text=" · "/>
                                        <Run Text="{Binding TimeText}"/>
                                    </TextBlock>
                                </StackPanel>

                                <Border Grid.Column="2"
                                        Padding="6,2" CornerRadius="2"
                                        BorderBrush="#FF243552" BorderThickness="1"
                                        Cursor="Hand"
                                       >
                                    <TextBlock Text="确认" FontFamily="Consolas"
                                               FontSize="10" Foreground="#FF3D5570"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ══ 任务队列 ══ -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <Grid Grid.Row="0" Margin="14,8,14,6">
                <TextBlock Text="任务队列" FontSize="10" FontWeight="SemiBold"
                           Foreground="#FF3D5570"/>
                <TextBlock HorizontalAlignment="Right"
                           FontFamily="Consolas" FontSize="10"
                           Foreground="#FF3D5570"
                           Text="{Binding TotalTaskCount, StringFormat={}{0} 条}"/>
            </Grid>

            <!-- 列表 -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding TaskQueue}"
                     ItemContainerStyle="{StaticResource ListItemStyle}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       FontFamily="Consolas" FontSize="10"
                                       Foreground="#FF3D5570"
                                       Text="{Binding ShortId}"
                                       VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding TaskName}"
                                           FontSize="12" Foreground="#FFDDEEFF"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock FontFamily="Consolas" FontSize="10"
                                           Foreground="#FF3D5570" Margin="0,2,0,0"
                                           Text="{Binding RouteText}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <!-- 状态标签 -->
                            <Border Grid.Column="2">
                                <Border.Style>
                                    <Style TargetType="Border"
                                           BasedOn="{StaticResource TaskBadge}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}"
                                                         Value="Executing">
                                                <Setter Property="Background"  Value="#1A00D8FF"/>
                                                <Setter Property="BorderBrush" Value="#3300D8FF"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}"
                                                         Value="Done">
                                                <Setter Property="Background"  Value="#1A00E5A0"/>
                                                <Setter Property="BorderBrush" Value="#3300E5A0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="10" FontWeight="SemiBold"
                                           >
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"       Value="等待"/>
                                            <Setter Property="Foreground" Value="#FF3D5570"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}"
                                                             Value="Executing">
                                                    <Setter Property="Text"       Value="执行"/>
                                                    <Setter Property="Foreground" Value="#FF00D8FF"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}"
                                                             Value="Done">
                                                    <Setter Property="Text"       Value="完成"/>
                                                    <Setter Property="Foreground" Value="#FF00E5A0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

    </Grid>
</UserControl>
